{
  "manifest_version": 2,
  "name": "Obsidian Source Note Creator",
  "version": "2.0",
  "description": "Save the current page as an Obsidian source note with one click or right-click.",
  "browser_specific_settings": {
    "gecko": {
      "id": "obsidian-source-note@ashley",
      "strict_min_version": "109.0"
    }
  },
  "icons": {
    "48": "icon-48.png",
    "96": "icon-96.png"
  },
  "permissions": [
    "activeTab",
    "contextMenus",
    "notifications",
    "storage"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_icon": "icon-48.png",
    "default_popup": "popup.html",
    "default_title": "Save as Source Note"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  }
}
